# Telegram bot token from @BotFather. Without it the API still runs,
# but Telegram auth and notifications are disabled (use DEV_AUTH).
BOT_TOKEN=

# Secret for signing session JWTs. Set to a long random string in production.
JWT_SECRET=change-me

# Public URL of the mini app (used by the bot's "open app" buttons).
WEBAPP_URL=https://example.com

# Telegram user id that becomes the community owner on first login.
OWNER_TG_ID=

# libsql database. File path by default; set a libsql:// URL for Turso.
DATABASE_URL=file:./data/lineup.db
# DATABASE_AUTH_TOKEN=

# Directory for uploaded photos / QR images.
UPLOAD_DIR=./data/uploads

# Allow /api/auth/dev login as any seeded user (NEVER enable in production).
DEV_AUTH=0

PORT=3010
